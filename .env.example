# Copy to .env and fill in your Supabase project values (Project Settings -> API).
# These are EXPO_PUBLIC_ variables: they are inlined into the client bundle,
# so only ever put the anon/publishable key here, never the service role key.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
